# --------------------------------------------------------------- brew.env ♠ ---
#
#   homebrew environment configuration
#
#   homebrew does not read from XDG config dirs natively — this file is the
#   dotfiles-managed substitute. source it from .zprofile:
#
#       source "$HOME/.config/brew/brew.env"
#
# ------------------------------------------------------------------------------

# point brew bundle at this directory's Brewfile
export HOMEBREW_BUNDLE_FILE="$HOME/.config/brew/Brewfile"

# disable usage analytics
export HOMEBREW_NO_ANALYTICS=1

# suppress env var hints in brew output
export HOMEBREW_NO_ENV_HINTS=1

# auto-remove cached old versions after 30 days
export HOMEBREW_CLEANUP_MAX_AGE_DAYS=30

# check for updates at most once per day (default is every 5 minutes, which
# adds noticeable latency to the first brew command of each session)
export HOMEBREW_AUTO_UPDATE_SECS=86400
