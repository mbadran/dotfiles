      "Bash(base64:*)",
      "Bash(md5:*)",
      "Bash(shasum:*)",

      "Bash(eza:*)",
      "Bash(bat:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(dust:*)",
      "Bash(jq:*)",

      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(bash:*)",
      "Bash(python3:*)",

      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr checks*)",
      "Bash(gh api*)",
      "Bash(gh repo view*)",
      "Bash(gh label list*)",
      "Bash(gh project list*)",
      "Bash(gh project view*)",

      "Skill(update-config)"
    ],
    "ask": [
      "Bash(git add:*)",
      "Bash(git commit)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git push --delete*)",
      "Bash(git push * --delete*)",
      "Bash(git -C * push*)",
      "Bash(git --git-dir * push*)",
      "Bash(git reset:*)",
      "Bash(git reset --hard*)",
      "Bash(git rebase:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git checkout:*)",
      "Bash(git restore:*)",
      "Bash(git branch -D*)",
      "Bash(git branch -d*)",
      "Bash(git -C * branch -D*)",
      "Bash(git -C * branch -d*)",
      "Bash(git tag -d*)",
      "Bash(git tag --delete*)",
      "Bash(git worktree remove*)",
      "Bash(git -C * worktree remove*)",
      "Bash(git clean:*)",
      "Bash(git stash drop*)",
      "Bash(git stash clear*)",

      "Bash(rm:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",

      "Bash(brew install:*)",
      "Bash(brew uninstall:*)",
      "Bash(brew upgrade:*)",
      "Bash(brew untap:*)",

      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm un:*)",
      "Bash(npm publish:*)",
      "Bash(npx:*)",
      "Bash(node:*)",

      "Bash(gh issue create*)",
      "Bash(gh issue close*)",
      "Bash(gh issue edit*)",
      "Bash(gh issue delete*)",
      "Bash(gh pr create*)",
      "Bash(gh pr close*)",
      "Bash(gh pr merge*)",
      "Bash(gh pr edit*)",
      "Bash(gh repo create*)",
      "Bash(gh repo delete*)"
    ],
    "deny": [],
    "additionalDirectories": [
      "~/.config",
      "~/.claude",
      "/opt/homebrew"
    ]
  },
  "effortLevel": "xhigh",
  "theme": "dark-daltonized",
  "model": "opus",
  "editorMode": "vim",
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/claude/scripts/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/claude/scripts/session-end.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  }
}
