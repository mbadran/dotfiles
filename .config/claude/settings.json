      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(tree:*)",
      "Bash(comm:*)",

      "Bash(grep:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(diff:*)",

      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(env)",
      "Bash(printenv:*)",
      "Bash(date:*)",
      "Bash(uname:*)",
      "Bash(id)",
      "Bash(whoami)",
      "Bash(ps:*)",
      "Bash(lsof:*)",
      "Bash(sw_vers:*)",
      "Bash(defaults read:*)",
      "Bash(plutil:*)",

      "Bash(xxd:*)",
