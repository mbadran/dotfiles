      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(whoami)",
      "Bash(xxd:*)",
      "Skill(update-config)",
      "WebFetch",
      "WebSearch",
      "mcp__plugin_github_github__get_*",
      "mcp__plugin_github_github__issue_read",
      "mcp__plugin_github_github__list_*",
      "mcp__plugin_github_github__pull_request_read",
      "mcp__plugin_github_github__search_*"
    ],
    "deny": [
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | sudo *)",
      "Bash(curl * | zsh*)",
      "Bash(dd if=* of=/dev/*)",
      "Bash(dd of=/dev/*)",
      "Bash(gh *)",
      "Bash(gh)",
      "Bash(gh:*)",
      "Bash(git push --force* * main:*)",
      "Bash(git push --force* * master:*)",
      "Bash(git push -f * main:*)",
      "Bash(git push -f * master:*)",
      "Bash(git push * --delete main:*)",
      "Bash(git push * --delete master:*)",
      "Bash(git push * --force* main:*)",
      "Bash(git push * --force* master:*)",
      "Bash(git push * -f * main:*)",
      "Bash(git push * -f * master:*)",
      "Bash(git push * :main:*)",
      "Bash(git push * :master:*)",
      "Bash(mkfs.*:*)",
      "Bash(mkfs:*)",
      "Bash(rm -rf \"$HOME\"*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /System*)",
      "Bash(rm -rf /etc*)",
      "Bash(rm -rf /usr*)",
      "Bash(sudo rm -rf:*)",
      "Bash(wget * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | zsh*)",
      "mcp__plugin_github_github__push_files"
    ],
    "ask": [
      "Bash(git clean:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git reflog expire:*)",
      "Bash(git stash clear*)",
      "Bash(git stash drop*)",
      "Bash(npm publish:*)"
    ],
    "additionalDirectories": [
      "~/.config",
      "~/.claude",
      "/opt/homebrew"
    ]
  },
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"${CLAUDE_PROJECT_DIR:-.}/.remember/logs\"",
            "timeout": 2
          },
          {
            "type": "command",
            "command": "bash ~/.config/claude/hooks/session/start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/claude/hooks/session/end.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y ccstatusline@latest --hook"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
